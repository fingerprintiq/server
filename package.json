{
  "name": "@fingerprintiq/server",
  "version": "0.4.0",
  "description": "Server-side request fingerprinting middleware — classify API callers as browsers, AI agents, CLI tools, or bots",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.mjs",
      "require": "./dist/hono.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.mjs",
      "require": "./dist/express.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "hono": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^4.1.4",
    "express": "^5.2.1",
    "hono": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.4"
  },
  "license": "MIT",
  "keywords": [
    "fingerprint",
    "api",
    "middleware",
    "bot-detection",
    "agent-detection",
    "ai-agent",
    "caller-classification",
    "hono",
    "express"
  ],
  "author": "FingerprintIQ <hello@fingerprintiq.com> (https://fingerprintiq.com)",
  "homepage": "https://fingerprintiq.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fingerprintiq/server.git"
  },
  "bugs": "https://github.com/fingerprintiq/server/issues",
  "publishConfig": {
    "access": "public"
  }
}
